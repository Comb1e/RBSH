# 🤖 LLM Service Configuration (Alibaba Cloud Bailei / OpenAI Compatible)
LLM_PROVIDER=openai  # openai, anthropic

OPENAI_API_KEY=sk-..,
OPENAI_API_KEY=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus-latest

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-4-6-sonnet

# ⚙️ Agent running parameters
AGENT_MAX_ITERATIONS=5  # cap on generator ↔ evaluator cycles
AGENT_TEMPERATURE=0
ENABLE_STREAMING=true
PASSING_THRESHOLD=7     # minimum score to accept output
TASK_BUDGET=40_000      # token ceiling per agent session
PASSING_THRESHOLD=7     # minimum score to accept output

# 📝 Logging and Debugging
LOG_LEVEL=info
NODE_ENV=development