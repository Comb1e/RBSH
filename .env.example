# 🤖 LLM Service Configuration (OpenAI Compatible)
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus-latest

# ⚙️ Agent running parameters
AGENT_MAX_ITERATIONS=5  # cap on generator ↔ evaluator cycles
AGENT_TEMPERATURE=0
ENABLE_STREAMING=true
TASK_BUDGET=40_000      # token ceiling per agent session

# 📝 Logging and Debugging
LOG_LEVEL=info
NODE_ENV=development
